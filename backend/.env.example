# ArogyaAI Production .env Configuration
# Copy this to .env and fill in your real values
# NEVER commit .env to version control

# ── AI Engine ───────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=2000
TEMPERATURE=0.45

# ── Database (Supabase) ─────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ── Security ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE-THIS-IN-PRODUCTION-MIN-64-CHARS-RANDOM-STRING-HERE-NOW
JWT_EXPIRE_HOURS=168
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS (comma-separated, no wildcards in production) ──────────
CORS_ORIGINS=https://arogyaai.in,https://www.arogyaai.in

# ── Payment (Razorpay) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxx
RAZORPAY_SECRET=your-razorpay-secret-key

# ── Infrastructure ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
PORT=8000
APP_ENV=production

# ── Rate Limiting ───────────────────────────────────────────────
FREE_DAILY_QUERIES=5
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── Admin Panel ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-admin-panel-secret-key-here

# ── Cache ───────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
